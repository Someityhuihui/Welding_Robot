//                                                           const std::vector<Eigen::Vector3f>& gradients) {
//     std::vector<float> responses(cloud->points.size(), 0.0f);

//     for (size_t i = 0; i < cloud->points.size(); i++) {
//         Eigen::Matrix3f H = buildHessianMatrix(gradients[i]);
//         responses[i] = computeEigenvalueRatio(H);
//     }
    
//     return responses;
// }

float EdgeIntensityDetector::computeResponse(CloudPtr cloud, int idx) {
    // 只调用一次 computeIntensity
    float intensity = computeIntensity(cloud, idx, radius_);
    if (intensity < 0.01f) return 0.0f;
    
    // 梯度：使用论文的简化公式，不需要重新计算所有邻居的强度
    // 实际上，梯度可以用强度变化率近似
    pcl::KdTreeFLANN<pcl::PointXYZ> kdtree;
    kdtree.setInputCloud(cloud);
    
    std::vector<int> indices;
    std::vector<float> distances;
    kdtree.radiusSearch(cloud->points[idx], radius_, indices, distances);
    
    if (indices.size() < 2) return 0.0f;
    
    // 计算梯度：取强度变化最大的方向
    float max_grad = 0;
    for (int j : indices) {
        if (j == idx) continue;
        float dist = distances[j - (j > idx ? 1 : 0)];  // 小心索引
        if (dist < 1e-6) continue;
        
        float neigh_intensity = computeIntensity(cloud, j, radius_);
        float grad_mag = std::abs(neigh_intensity - intensity) / dist;
        if (grad_mag > max_grad) {
            max_grad = grad_mag;
        }
    }
    
    // 简化的响应值：强度 × 最大梯度
    return intensity * max_grad;
}


