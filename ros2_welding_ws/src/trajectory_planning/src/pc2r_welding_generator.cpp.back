// 批量计算所有点的强度（一次KNN，避免重复计算）
void EdgeIntensityDetector::computeIntensity(CloudPtr cloud, std::vector<float>& intensities) {
    size_t n = cloud->points.size();
    intensities.resize(n, 0.0f);
    
    pcl::KdTreeFLANN<pcl::PointXYZ> kdtree;
    kdtree.setInputCloud(cloud);
    
    #pragma omp parallel for schedule(dynamic, 100)
    for (size_t i = 0; i < n; i++) {
        std::vector<int> indices;
        std::vector<float> distances;
        
        // 自适应半径：确保至少有 min_neighbors_ 个点
        float search_r = radius_;
        int max_attempts = 5;
        for (int attempt = 0; attempt < max_attempts; attempt++) {
            kdtree.radiusSearch(cloud->points[i], search_r, indices, distances);
            if (indices.size() >= (size_t)min_neighbors_) break;
            search_r += 0.002f;  // 逐步扩大半径
        }
        
        if (indices.size() < 3) continue;
        
        // 计算几何中心
        Eigen::Vector3f centroid(0, 0, 0);
        for (int idx : indices) {
            centroid += cloud->points[idx].getVector3fMap();
        }
        centroid /= indices.size();
        
        // 论文公式(20): I = (1/r) * ||pi - centroid||
        Eigen::Vector3f pi = cloud->points[i].getVector3fMap();
        float intensity = (pi - centroid).norm() / search_r;
        
        intensities[i] = intensity;
    }
}


