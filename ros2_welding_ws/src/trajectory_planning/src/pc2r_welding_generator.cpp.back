Eigen::Vector3f EdgeIntensityDetector::computeGradient(CloudPtr cloud, int idx, float r) {
    float base_intensity = computeIntensity(cloud, idx, r);
    Eigen::Vector3f grad(0, 0, 0);
    
    pcl::KdTreeFLANN<pcl::PointXYZ> kdtree;
    kdtree.setInputCloud(cloud);
    
    std::vector<int> indices;
    std::vector<float> distances;
    kdtree.radiusSearch(cloud->points[idx], r, indices, distances);
    
    for (int j : indices) {
        if (j == idx) continue;
        float neigh_intensity = computeIntensity(cloud, j, r);
        Eigen::Vector3f diff = cloud->points[j].getVector3fMap() - cloud->points[idx].getVector3fMap();
        float dist = diff.norm();
        if (dist > 1e-6) {
            grad += (neigh_intensity - base_intensity) / dist * diff.normalized();
        }
    }
    
    return grad;
}

Eigen::Matrix3f EdgeIntensityDetector::buildHessianMatrix(const Eigen::Vector3f& grad) {
    Eigen::Matrix3f H;
    H << grad.x() * grad.x(), grad.x() * grad.y(), grad.x() * grad.z(),
         grad.y() * grad.x(), grad.y() * grad.y(), grad.y() * grad.z(),
         grad.z() * grad.x(), grad.z() * grad.y(), grad.z() * grad.z();
    return H;
}

float EdgeIntensityDetector::computeEigenvalueRatio(const Eigen::Matrix3f& H) {
    float trace = H.trace();
    float det = H.determinant();
    
    if (std::abs(det) < 1e-10) return 0.0f;
    
    float ratio = trace / std::cbrt(std::abs(det));
    return ratio;
}


